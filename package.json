{
  "name": "@gadagi/design-system",
  "version": "1.0.8",
  "description": "Design system for gadagi micro-frontends",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "src/styles"
  ],
  "style": "src/styles/index.scss",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.esm.js",
      "require": "./dist/index.js"
    },
    "./styles": "./src/styles/index.scss",
    "./variables": "./src/styles/variables.scss",
    "./utilities": "./src/styles/utilities.scss",
    "./typography": "./src/styles/typography.scss",
    "./layout": "./src/styles/layout.scss",
    "./effects": "./src/styles/effects.scss",
    "./mixins": "./src/styles/mixins.scss"
  },
  "scripts": {
    "build": "tsc && echo 'export * from \"./src/index\";' > dist/adi-design-system/index.js",
    "dev": "tsc --watch",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build -o docs"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "css-loader": "^7.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.0.0",
    "typescript": "^5.0.0",
    "webpack": "^5.0.0",
    "webpack-cli": "^5.0.0",
    "sass": "^1.77.0",
    "sass-loader": "^14.2.1",
    "@storybook/addon-essentials": "^8.2.2",
    "@storybook/react-webpack5": "^8.2.2",
    "storybook": "^8.2.2"
  }
}
